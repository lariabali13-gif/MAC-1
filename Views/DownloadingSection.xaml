<UserControl x:Class="MAC_1.Views.DownloadingSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:conv="clr-namespace:MAC_1.Converters"
             xmlns:views="clr-namespace:MAC_1.Views"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:FileIconConverter x:Key="FileIconConverter"/>
    </UserControl.Resources>
    <Grid>
        <Border Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="28,20,28,20">
                    <!-- HEADER -->
                    <Grid Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Downloads" FontSize="22" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                            <Border Background="#3B82F6" CornerRadius="10" Padding="8,3" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AllCount}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                    <!-- FILTER TABS -->
                    <Border Background="#F8FAFC" CornerRadius="12" Padding="5,5" Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="TabAll" Background="#3B82F6" CornerRadius="8" Padding="13,6" Cursor="Hand" MouseLeftButtonDown="FilterTab_Click" Tag="All">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="All" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    <Border Background="#2563EB" CornerRadius="6" Padding="5,2" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding AllCount}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Border x:Name="TabDownloading" Background="Transparent" CornerRadius="8" Padding="13,6" Cursor="Hand" Margin="3,0,0,0" MouseLeftButtonDown="FilterTab_Click" Tag="Downloading">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Downloading" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                    <Border Background="#E5E7EB" CornerRadius="6" Padding="5,2" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding ActiveDownloads}" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Border x:Name="TabPaused" Background="Transparent" CornerRadius="8" Padding="13,6" Cursor="Hand" Margin="3,0,0,0" MouseLeftButtonDown="FilterTab_Click" Tag="Paused">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Paused" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                    <Border Background="#E5E7EB" CornerRadius="6" Padding="5,2" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding PausedDownloads}" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Border x:Name="TabFailed" Background="Transparent" CornerRadius="8" Padding="13,6" Cursor="Hand" Margin="3,0,0,0" MouseLeftButtonDown="FilterTab_Click" Tag="Failed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Failed" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                    <Border Background="#E5E7EB" CornerRadius="6" Padding="5,2" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding FailedDownloads}" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Downloads List -->
                    <ItemsControl ItemsSource="{Binding FilteredDownloads}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FAFBFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14" Padding="16,14" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="#EFF6FF">
                                                <Image Source="{Binding Filename, Converter={StaticResource FileIconConverter}}"
                                                       Width="28" Height="28" RenderOptions.BitmapScalingMode="HighQuality"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Filename}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}" Value="Completed">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="{Binding SizeDisplay}" FontSize="11" Foreground="#64748B"/>
                                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                                    <TextBlock Text="{Binding DownloadedDisplay}" FontSize="11" Foreground="#64748B"/>
                                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                                    <TextBlock Text="{Binding StateText}" FontSize="11" Foreground="#64748B"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}" Value="Completed">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="{Binding SizeDisplay}" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                                    <TextBlock Text="Completed" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- ACTIVE buttons -->
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="Completed">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Border Width="30" Height="30" CornerRadius="7" Background="#EFF6FF" Cursor="Hand" Margin="0,0,5,0" MouseLeftButtonDown="CardPause_Click" Tag="{Binding}">
                                                    <fa:ImageAwesome Width="11" Foreground="#3B82F6" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <fa:ImageAwesome.Style>
                                                            <Style TargetType="fa:ImageAwesome">
                                                                <Setter Property="Icon" Value="Pause"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding State}" Value="Paused">
                                                                        <Setter Property="Icon" Value="Play"/>
                                                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding State}" Value="Failed">
                                                                        <Setter Property="Icon" Value="Refresh"/>
                                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </fa:ImageAwesome.Style>
                                                    </fa:ImageAwesome>
                                                </Border>
                                                <Border Width="30" Height="30" CornerRadius="7" Background="#FEF2F2" Cursor="Hand" Margin="0,0,5,0" MouseLeftButtonDown="CardRemove_Click" Tag="{Binding}">
                                                    <fa:ImageAwesome Icon="Trash" Width="11" Foreground="#EF4444" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Width="30" Height="30" CornerRadius="7" Background="#F1F5F9" Cursor="Hand" MouseLeftButtonUp="CardMore_Click" Tag="{Binding}">
                                                    <fa:ImageAwesome Icon="EllipsisH" Width="11" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                            <!-- COMPLETED buttons -->
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="Completed">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Border Width="30" Height="30" CornerRadius="7" Background="#ECFDF5" Cursor="Hand" Margin="0,0,5,0" MouseLeftButtonDown="CardOpenFile_Click" Tag="{Binding}">
                                                    <fa:ImageAwesome Icon="File" Width="11" Foreground="#10B981" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Width="30" Height="30" CornerRadius="7" Background="#EFF6FF" Cursor="Hand" Margin="0,0,5,0" MouseLeftButtonDown="CardOpenFolder_Click" Tag="{Binding}">
                                                    <fa:ImageAwesome Icon="FolderOpen" Width="11" Foreground="#3B82F6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Width="30" Height="30" CornerRadius="7" Background="#FEF2F2" Cursor="Hand" Margin="0,0,5,0" MouseLeftButtonDown="CardRemove_Click" Tag="{Binding}">
                                                    <fa:ImageAwesome Icon="Trash" Width="11" Foreground="#EF4444" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Width="30" Height="30" CornerRadius="7" Background="#F1F5F9" Cursor="Hand" MouseLeftButtonUp="CardMore_Click" Tag="{Binding}">
                                                    <fa:ImageAwesome Icon="EllipsisH" Width="11" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                        <!-- Progress bar -->
                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Margin="0,12,0,0">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Height" Value="5"/>
                                                    <Setter Property="Background" Value="#E5E7EB"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ProgressBar">
                                                                <Grid>
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                                                                    <Border x:Name="PART_Track" CornerRadius="3"/>
                                                                    <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                                                                        <Border.Background>
                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                <GradientStop Color="#3B82F6" Offset="0"/>
                                                                                <GradientStop Color="#60A5FA" Offset="1"/>
                                                                            </LinearGradientBrush>
                                                                        </Border.Background>
                                                                    </Border>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="Completed">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Paused">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ProgressBar">
                                                                        <Grid>
                                                                            <Border Background="#E5E7EB" CornerRadius="3"/>
                                                                            <Border x:Name="PART_Track" CornerRadius="3"/>
                                                                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                                                                                <Border.Background>
                                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                        <GradientStop Color="#F59E0B" Offset="0"/>
                                                                                        <GradientStop Color="#FBBF24" Offset="1"/>
                                                                                    </LinearGradientBrush>
                                                                                </Border.Background>
                                                                            </Border>
                                                                        </Grid>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Failed">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ProgressBar">
                                                                        <Grid>
                                                                            <Border Background="#E5E7EB" CornerRadius="3"/>
                                                                            <Border x:Name="PART_Track" CornerRadius="3"/>
                                                                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                                                                                <Border.Background>
                                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                        <GradientStop Color="#EF4444" Offset="0"/>
                                                                                        <GradientStop Color="#F87171" Offset="1"/>
                                                                                    </LinearGradientBrush>
                                                                                </Border.Background>
                                                                            </Border>
                                                                        </Grid>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <!-- Speed row -->
                                        <Grid Margin="0,7,0,0">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="Completed">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <fa:ImageAwesome Icon="ArrowDown" Width="9" Foreground="#3B82F6" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding Speed}" FontSize="11" FontWeight="SemiBold" Foreground="#3B82F6" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TimeLeft}" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBlock Text="{Binding ProgressDisplay}" FontSize="13" FontWeight="Bold" Foreground="#3B82F6" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state -->
                    <StackPanel x:Name="EmptyDownloadsPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0" Visibility="Collapsed">
                        <Border Width="100" Height="100" CornerRadius="50" Background="#F3F4F6" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="CloudDownload" Width="44" Foreground="#D1D5DB" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Downloads are empty" FontSize="18" FontWeight="SemiBold" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                        <TextBlock Text="Add a download to get started" FontSize="13" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Shared Context Popup (outside DataTemplate so x:Name works) -->
        <Popup x:Name="SharedPopup" AllowsTransparency="True" Placement="Bottom"
               StaysOpen="False" Closed="SharedPopup_Closed">
            <views:ContextPopup x:Name="SharedContextPopup"/>
        </Popup>
    </Grid>
</UserControl>
