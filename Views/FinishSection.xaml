<UserControl x:Class="MAC_1.Views.FinishSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:conv="clr-namespace:MAC_1.Converters"
             xmlns:views="clr-namespace:MAC_1.Views"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900">
    <UserControl.Resources>
        <conv:FileIconConverter x:Key="FileIconConverter"/>
    </UserControl.Resources>
    <Grid>
        <Border Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="28,20,28,20">
                    <!-- HEADER -->
                    <Grid Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#059669" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <fa:ImageAwesome Icon="CheckCircle" Width="14" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Finished" FontSize="22" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                            <Border Background="#10B981" CornerRadius="10" Padding="8,3" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CompletedCount}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Empty state -->
                    <StackPanel x:Name="EmptyFinishPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0" Visibility="Collapsed">
                        <Border Width="100" Height="100" CornerRadius="50" Background="#F3F4F6" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="CheckCircle" Width="44" Foreground="#D1D5DB" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="No completed downloads yet" FontSize="18" FontWeight="SemiBold" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                        <TextBlock Text="Completed downloads will appear here" FontSize="13" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Completed Downloads List -->
                    <ItemsControl ItemsSource="{Binding CompletedDownloads}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FAFBFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14" Padding="16,14" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="#ECFDF5">
                                                <Image Source="{Binding Filename, Converter={StaticResource FileIconConverter}}"
                                                       Width="28" Height="28" RenderOptions.BitmapScalingMode="HighQuality"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Filename}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding SizeDisplay}" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                                    <TextBlock Text="Completed" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="30" Height="30" CornerRadius="7" Background="#ECFDF5" Cursor="Hand" Margin="0,0,5,0" MouseLeftButtonDown="CardOpenFile_Click" Tag="{Binding}">
                                                    <fa:ImageAwesome Icon="File" Width="11" Foreground="#10B981" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Width="30" Height="30" CornerRadius="7" Background="#EFF6FF" Cursor="Hand" Margin="0,0,5,0" MouseLeftButtonDown="CardOpenFolder_Click" Tag="{Binding}">
                                                    <fa:ImageAwesome Icon="FolderOpen" Width="11" Foreground="#3B82F6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Width="30" Height="30" CornerRadius="7" Background="#FEF2F2" Cursor="Hand" Margin="0,0,5,0" MouseLeftButtonDown="CardRemove_Click" Tag="{Binding}">
                                                    <fa:ImageAwesome Icon="Trash" Width="11" Foreground="#EF4444" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Width="30" Height="30" CornerRadius="7" Background="#F1F5F9" Cursor="Hand" MouseLeftButtonUp="CardMore_Click" Tag="{Binding}">
                                                    <fa:ImageAwesome Icon="EllipsisH" Width="11" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Shared Context Popup -->
        <Popup x:Name="SharedPopup" AllowsTransparency="True" Placement="Bottom"
               StaysOpen="False" Closed="SharedPopup_Closed">
            <views:ContextPopup x:Name="SharedContextPopup"/>
        </Popup>
    </Grid>
</UserControl>
