<Window x:Class="MAC_1.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="MAC-1 Downloader" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen" Foreground="White" FontFamily="Roboto">

    <!-- Clean White Background -->
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8F9FA" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.5"/>
            <GradientStop Color="#F0F2F5" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <!-- 1. SIDE NAVBAR -->
        <Border x:Name="SidebarBorder" Grid.RowSpan="3" Width="220" Tag="Expanded" Background="#F0F2F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <!-- LOGO AREA with Collapse Icon Overlay -->
                <Grid Grid.Row="0" Margin="18,10,10,0"
                      MouseEnter="LogoArea_MouseEnter" MouseLeave="LogoArea_MouseLeave">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo Icon -->
                    <Border x:Name="LogoIconBorder" Width="42" Height="42" CornerRadius="10" Background="#0077FF" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <fa:ImageAwesome Icon="CloudDownload" Width="22" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Collapse Icon (Overlay on Logo) -->
                    <Border x:Name="CollapseOverlay" Grid.Column="0" Width="42" Height="42" CornerRadius="10"
                            Background="#0055CC" VerticalAlignment="Center" HorizontalAlignment="Left"
                            Cursor="Hand" Opacity="0" MouseLeftButtonDown="CollapseBtn_Click">
                        <fa:ImageAwesome Icon="Bars" Width="16" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Logo Text -->
                    <StackPanel x:Name="LogoTextPanel" Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="MAC-1" FontSize="18" FontWeight="Black" Foreground="#1A1A2E"/>
                        <TextBlock Text="Download Manager" FontSize="9" Foreground="#888" Margin="0,1,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- SEPARATOR LINE -->
                <Border Grid.Row="1" Height="1" Background="#E0E0E0" VerticalAlignment="Top" Margin="16,0"/>

                <Button x:Name="NavDashboard" Grid.Row="1" Style="{StaticResource SidebarButtonStyle}" Content="Dashboard" Click="NavButton_Click">
                    <Button.Tag>
                        <fa:ImageAwesome Icon="Dashboard" Width="20" Foreground="#0077FF"/>
                    </Button.Tag>
                </Button>
                <hc:Badge Grid.Row="2" Value="3" BadgeMargin="0,15,15,0">
                    <Button x:Name="NavDownloading" Style="{StaticResource SidebarButtonStyle}" Content="Downloading" Click="NavButton_Click">
                        <Button.Tag>
                            <fa:ImageAwesome Icon="Download" Width="20" Foreground="#0077FF"/>
                        </Button.Tag>
                    </Button>
                </hc:Badge>
                <Button x:Name="NavQueue" Grid.Row="3" Style="{StaticResource SidebarButtonStyle}" Content="Queue" Click="NavButton_Click">
                    <Button.Tag>
                        <fa:ImageAwesome Icon="ListOl" Width="20" Foreground="#0077FF"/>
                    </Button.Tag>
                </Button>
                <Button x:Name="NavTorrent" Grid.Row="4" Style="{StaticResource SidebarButtonStyle}" Content="Torrent" Click="NavButton_Click">
                    <Button.Tag>
                        <fa:ImageAwesome Icon="Magnet" Width="20" Foreground="#0077FF"/>
                    </Button.Tag>
                </Button>
                <Button x:Name="NavFinished" Grid.Row="5" Style="{StaticResource SidebarButtonStyle}" Content="Finished" Click="NavButton_Click">
                    <Button.Tag>
                        <fa:ImageAwesome Icon="CheckCircle" Width="20" Foreground="#0077FF"/>
                    </Button.Tag>
                </Button>
                <Button x:Name="NavHistory" Grid.Row="6" Style="{StaticResource SidebarButtonStyle}" Content="History" Click="NavButton_Click">
                    <Button.Tag>
                        <fa:ImageAwesome Icon="History" Width="20" Foreground="#0077FF"/>
                    </Button.Tag>
                </Button>
                <Button x:Name="NavSettings" Grid.Row="8" Style="{StaticResource SidebarButtonStyle}" Content="Settings" ToolTip="Rotate" Click="NavButton_Click">
                    <Button.Tag>
                        <fa:ImageAwesome Icon="Gear" Width="20" Foreground="#0077FF"/>
                    </Button.Tag>
                </Button>
            </Grid>
        </Border>

        <!-- 2. TOP NAVBAR (White Theme) -->
        <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <!-- Search Bar -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Spacer -->
                    <ColumnDefinition Width="20"/>
                    <!-- Add New URL -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Spacer -->
                    <ColumnDefinition Width="12"/>
                    <!-- Pause / Resume -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Spacer -->
                    <ColumnDefinition Width="12"/>
                    <!-- Scheduler -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- * pushes right icons -->
                    <ColumnDefinition Width="*"/>
                    <!-- Theme -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Notification (corner) -->
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search Bar -->
                <TextBox x:Name="SearchBox" Grid.Column="0" Style="{StaticResource ModernSearchBox}"
                         VerticalAlignment="Center" GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"/>

                <!-- + Add New URL -->
                <Button Grid.Column="2" Content="ADD NEW URL" Style="{StaticResource PulseAddButtonStyle}" Cursor="Hand" VerticalAlignment="Center"/>

                <!-- Pause / Resume Toggle -->
                <Button x:Name="PauseResumeBtn" Grid.Column="4" Style="{StaticResource PauseResumeButtonStyle}"
                        Cursor="Hand" VerticalAlignment="Center" Click="PauseResumeBtn_Click"/>

                <!-- Scheduler -->
                <Button Grid.Column="6" Style="{StaticResource SchedulerButtonStyle}" Cursor="Hand" VerticalAlignment="Center"
                        ToolTip="Scheduler">
                    <ContentPresenter Content="Scheduler"/>
                </Button>

                <!-- Theme / Moon Icon (left side) -->
                <Button Grid.Column="8" Style="{StaticResource TopNavIconButtonStyle}" VerticalAlignment="Center"
                        ToolTip="Toggle Dark Theme">
                    <Path Data="M12,3c-4.97,0 -9,4.03 -9,9s4.03,9 9,9 9,-4.03 9,-9c0,-0.46 -0.04,-0.92 -0.1,-1.36 -0.98,1.37 -2.58,2.26 -4.4,2.26 -2.98,0 -5.4,-2.42 -5.4,-5.4 0,-1.81 0.89,-3.42 2.26,-4.4C12.92,3.04 12.46,3 12,3z"
                          Fill="#888" Width="16" Height="16" Stretch="Uniform"/>
                </Button>

                <!-- Notification Icon (corner) -->
                <Button Grid.Column="9" Style="{StaticResource TopNavIconButtonStyle}" VerticalAlignment="Center"
                        ToolTip="Notifications">
                    <Grid>
                        <Path Data="M12,22c1.1,0 2,-0.9 2,-2h-4c0,1.1 0.9,2 2,2zm6,-6v-5c0,-3.07 -1.63,-5.64 -4.5,-6.32V4c0,-0.83 -0.67,-1.5 -1.5,-1.5s-1.5,0.67 -1.5,1.5v0.68C7.64,5.36 6,7.92 6,11v5l-2,2v1h16v-1l-2,-2z"
                              Fill="#888" Width="16" Height="16" Stretch="Uniform"/>
                        <Border Width="14" Height="14" CornerRadius="7" Background="#FF3366" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,-4,-4,0">
                            <TextBlock Text="2" Foreground="White" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <!-- 3. MAIN DOWNLOAD AREA (Content Host) -->
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="#E8E8E8" BorderThickness="0,0,1,0" Background="White">
            <ContentControl x:Name="MainContent" Margin="0"/>
        </Border>

        <!-- 4. RIGHT PANEL (Empty - content later) -->
        <Border Grid.Row="1" Grid.Column="2" Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="0,0,1,0"/>

        <!-- 6. BOTTOM NAVBAR -->
        <!-- 6. BOTTOM NAVBAR (White Theme) -->
        <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Global Progress Bar -->
                <ProgressBar Grid.Row="0" Value="65" Height="2" Background="Transparent" Foreground="#0077FF" BorderThickness="0"/>

                <!-- Content Area -->
                <Grid Grid.Row="1" Margin="15,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Ellipse Width="6" Height="6" Style="{StaticResource BlinkingDotStyle}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="STATUS:" Style="{StaticResource BottomNavTextStyle}" Foreground="#888"/>
                        <TextBlock Text="{Binding ActiveStatusText}" Style="{StaticResource BottomNavValueStyle}" Foreground="#00AA00"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <fa:ImageAwesome Icon="Database" Width="10" Foreground="#AAA" Margin="0,0,5,0"/>
                        <TextBlock Text="DISK:" Style="{StaticResource BottomNavTextStyle}" Foreground="#888"/>
                        <TextBlock Text="{Binding DiskSpeed}" Style="{StaticResource BottomNavValueStyle}" Foreground="#333"/>

                        <fa:ImageAwesome Icon="Link" Width="10" Foreground="#AAA" Margin="0,0,5,0"/>
                        <TextBlock Text="CONNS:" Style="{StaticResource BottomNavTextStyle}" Foreground="#888"/>
                        <TextBlock Text="{Binding ActiveCount}" Style="{StaticResource BottomNavValueStyle}" Foreground="#333"/>

                        <Button Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Open Downloads Folder">
                            <fa:ImageAwesome Icon="FolderOpen" Width="14" Foreground="#0077FF" Opacity="0.8"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>