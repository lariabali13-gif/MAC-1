<Window x:Class="MAC_1.Views.NewCategoryPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Categories" Height="600" Width="860"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" Topmost="True">

    <Window.Resources>
        <!-- Rounded TextBox -->
        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded Button base -->
        <Style x:Key="RoundedButtonBase" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,11"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,10"/>
        </Style>

        <Style x:Key="BrowseButton" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style x:Key="AddNewCategoryButton" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#6366F1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,11"/>
        </Style>

        <!-- Close (X) button -->
        <Style x:Key="CloseIconButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Delete (trash) icon button -->
        <Style x:Key="DeleteIconButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FEF2F2"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FCA5A5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom CheckBox -->
        <Style x:Key="RoundedCheckBox" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Box" Width="20" Height="20" CornerRadius="5"
                                Background="#6366F1" BorderBrush="#6366F1" BorderThickness="1.5">
                            <Path x:Name="Check" Data="M4,10 L8,14 L16,5" Stroke="White"
                                  StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Stretch="None" HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Box" Property="Background" Value="White"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#D1D5DB"/>
                                <Setter TargetName="Check" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Category list-row template -->
        <Style x:Key="CategoryRow" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="34" ShadowDepth="10" Opacity="0.16" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="24,20,24,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="#EEF0FF" VerticalAlignment="Top">
                    <Path Data="M3,5 L10,5 L12,8 L21,8 L21,18 L3,18 Z" Stroke="#6366F1" StrokeThickness="1.8"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Stretch="Uniform" Width="20" Height="20"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Manage Categories" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Create, edit or delete download categories" FontSize="12" Foreground="#9CA3AF" Margin="0,3,0,0"/>
                </StackPanel>

                <Button x:Name="CloseButton" Grid.Column="2" Style="{StaticResource CloseIconButton}" VerticalAlignment="Top" Content="✕"/>
            </Grid>

            <!-- BODY -->
            <Border Grid.Row="2" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Category list -->
                    <Grid Grid.Column="0" Margin="14,14,10,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Your Categories" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CategoriesPanel">

                                <!-- All Downloads -->
                                <Border Style="{StaticResource CategoryRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#DBEAFE">
                                            <Path Data="M3,5 L10,5 L12,8 L21,8 L21,18 L3,18 Z" Stroke="#2563EB" StrokeThickness="1.6"
                                                  StrokeLineJoin="Round" Fill="#2563EB" Stretch="Uniform" Width="17" Height="17"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,6,0" VerticalAlignment="Center">
                                            <TextBlock Text="All Downloads" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                            <TextBlock Text="C:\Users\bilal\Downloads" FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Style="{StaticResource DeleteIconButton}" Tag="AllDownloads">
                                            <Path Data="M4,6 L16,6 M8,6 L8,3 L12,3 L12,6 M6,6 L6,17 L14,17 L14,6" Stroke="#EF4444"
                                                  StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                  Stretch="Uniform" Width="15" Height="15"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Programs -->
                                <Border Style="{StaticResource CategoryRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#DCFCE7">
                                            <Path Data="M3,5 L10,5 L12,8 L21,8 L21,18 L3,18 Z" Stroke="#16A34A" StrokeThickness="1.6"
                                                  StrokeLineJoin="Round" Fill="#16A34A" Stretch="Uniform" Width="17" Height="17"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,6,0" VerticalAlignment="Center">
                                            <TextBlock Text="Programs" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                            <TextBlock Text="C:\Users\bilal\Downloads\Programs" FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Style="{StaticResource DeleteIconButton}" Tag="Programs">
                                            <Path Data="M4,6 L16,6 M8,6 L8,3 L12,3 L12,6 M6,6 L6,17 L14,17 L14,6" Stroke="#EF4444"
                                                  StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                  Stretch="Uniform" Width="15" Height="15"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Videos -->
                                <Border Style="{StaticResource CategoryRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#EDE9FE">
                                            <Path Data="M3,5 L17,5 L17,15 L3,15 Z M3,8 L17,8 M3,12 L17,12 M6,5 L6,15 M11,5 L11,15"
                                                  Stroke="#7C3AED" StrokeThickness="1.4" Stretch="Uniform" Width="17" Height="17"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,6,0" VerticalAlignment="Center">
                                            <TextBlock Text="Videos" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                            <TextBlock Text="C:\Users\bilal\Downloads\Videos" FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Style="{StaticResource DeleteIconButton}" Tag="Videos">
                                            <Path Data="M4,6 L16,6 M8,6 L8,3 L12,3 L12,6 M6,6 L6,17 L14,17 L14,6" Stroke="#EF4444"
                                                  StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                  Stretch="Uniform" Width="15" Height="15"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Music -->
                                <Border Style="{StaticResource CategoryRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#FFEDD5">
                                            <Path Data="M9,17 C9,18.1 8,19 6.5,19 C5,19 4,18.1 4,17 C4,15.9 5,15 6.5,15 C7,15 7.5,15.1 8,15.3 L8,5 L16,3 L16,15 C16,16.1 15,17 13.5,17 C12,17 11,16.1 11,15 C11,13.9 12,13 13.5,13 C14,13 14.5,13.1 15,13.3 L15,7 L9,8.5 Z"
                                                  Fill="#EA580C" Stretch="Uniform" Width="17" Height="17"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,6,0" VerticalAlignment="Center">
                                            <TextBlock Text="Music" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                            <TextBlock Text="C:\Users\bilal\Downloads\Music" FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Style="{StaticResource DeleteIconButton}" Tag="Music">
                                            <Path Data="M4,6 L16,6 M8,6 L8,3 L12,3 L12,6 M6,6 L6,17 L14,17 L14,6" Stroke="#EF4444"
                                                  StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                  Stretch="Uniform" Width="15" Height="15"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Images -->
                                <Border Style="{StaticResource CategoryRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#CCFBF1">
                                            <Path Data="M3,4 L17,4 L17,16 L3,16 Z M3,13 L8,9 L11,12 L14,8 L17,11 M6,8 A1,1 0 1 0 6,6 A1,1 0 0 0 6,8 Z"
                                                  Stroke="#0D9488" StrokeThickness="1.4" StrokeLineJoin="Round" Fill="Transparent"
                                                  Stretch="Uniform" Width="17" Height="17"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,6,0" VerticalAlignment="Center">
                                            <TextBlock Text="Images" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                            <TextBlock Text="C:\Users\bilal\Downloads\Images" FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Style="{StaticResource DeleteIconButton}" Tag="Images">
                                            <Path Data="M4,6 L16,6 M8,6 L8,3 L12,3 L12,6 M6,6 L6,17 L14,17 L14,6" Stroke="#EF4444"
                                                  StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                  Stretch="Uniform" Width="15" Height="15"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Compressed -->
                                <Border Style="{StaticResource CategoryRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#FCE7F3">
                                            <Path Data="M3,5 L10,5 L12,8 L21,8 L21,18 L3,18 Z" Stroke="#DB2777" StrokeThickness="1.6"
                                                  StrokeLineJoin="Round" Fill="#DB2777" Stretch="Uniform" Width="17" Height="17"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,6,0" VerticalAlignment="Center">
                                            <TextBlock Text="Compressed" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                            <TextBlock Text="C:\Users\bilal\Downloads\Compressed" FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Style="{StaticResource DeleteIconButton}" Tag="Compressed">
                                            <Path Data="M4,6 L16,6 M8,6 L8,3 L12,3 L12,6 M6,6 L6,17 L14,17 L14,6" Stroke="#EF4444"
                                                  StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                  Stretch="Uniform" Width="15" Height="15"/>
                                        </Button>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>

                        <Button x:Name="AddNewCategoryButton" Grid.Row="4" Style="{StaticResource AddNewCategoryButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="Add New Category" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Divider -->
                    <Border Grid.Column="1" Width="1" Background="#E5E7EB" Margin="0,14"/>

                    <!-- RIGHT: Add New Category form -->
                    <Grid Grid.Column="2" Margin="20,14,14,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Add New Category" FontSize="14.5" FontWeight="Bold" Foreground="#6366F1"/>

                        <!-- Category Name -->
                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Category Name" FontSize="13" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,8"/>
                            <TextBox x:Name="CategoryNameTextBox" Style="{StaticResource FieldTextBox}"
                                     Text="Enter category name..." Foreground="#9CA3AF"
                                     GotFocus="CategoryNameTextBox_GotFocus" LostFocus="CategoryNameTextBox_LostFocus"/>
                            <TextBlock Text="Choose a name that helps you identify this category" FontSize="11.5"
                                       Foreground="#9CA3AF" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Download Location -->
                        <StackPanel Grid.Row="4">
                            <TextBlock Text="Download Location" FontSize="13" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="DownloadLocationTextBox" Grid.Column="0" Style="{StaticResource FieldTextBox}"
                                         Text="C:\Users\bilal\Downloads"/>
                                <Button x:Name="BrowseButton" Grid.Column="2" Style="{StaticResource BrowseButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M3,6 L9,6 L11,8.5 L21,8.5 L21,18 L3,18 Z" Stroke="#374151" StrokeThickness="1.6"
                                              Stretch="Uniform" Width="15" Height="15" VerticalAlignment="Center"/>
                                        <TextBlock Text="Browse" Margin="7,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBlock Text="Select the default folder where files in this category will be saved"
                                       FontSize="11.5" Foreground="#9CA3AF" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Grid.Row="5" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Margin="0,0,0,0" VerticalAlignment="Bottom"/>

                        <!-- Category Options -->
                        <StackPanel Grid.Row="6">
                            <TextBlock Text="Category Options" FontSize="13" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="UseAsDefaultCheckBox" Style="{StaticResource RoundedCheckBox}" IsChecked="True" VerticalAlignment="Center"/>
                                <TextBlock Text="Use this folder as the default location" FontSize="13"
                                           Foreground="#374151" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Ellipse Width="15" Height="15" Stroke="#9CA3AF" StrokeThickness="1.4" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                <TextBlock Text="You can change this later from category settings" FontSize="11.5"
                                           Foreground="#9CA3AF" Margin="9,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- FOOTER -->
            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="CancelButton" Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Cancel"/>

                <Button x:Name="CreateCategoryButton" Grid.Column="3" Style="{StaticResource PrimaryButton}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="15" Height="15" Stroke="White" StrokeThickness="1.5" VerticalAlignment="Center"/>
                        <TextBlock Text="Create Category" Margin="7,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

        </Grid>
    </Border>
</Window>
