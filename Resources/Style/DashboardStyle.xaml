<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:fa="http://schemas.fontawesome.io/icons/">

    <!-- Dashboard Colors -->
    <SolidColorBrush x:Key="DashBlue" Color="#0077FF"/>
    <SolidColorBrush x:Key="DashGreen" Color="#22C55E"/>
    <SolidColorBrush x:Key="DashOrange" Color="#F97316"/>
    <SolidColorBrush x:Key="DashRed" Color="#EF4444"/>
    <SolidColorBrush x:Key="DashTextPrimary" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="DashTextSecondary" Color="#6B7280"/>
    <SolidColorBrush x:Key="DashTextMuted" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="DashBorder" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="DashCardBg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DashRowHover" Color="#F9FAFB"/>
    <SolidColorBrush x:Key="DashViewAll" Color="#0077FF"/>

    <!-- ===================== STAT CARD ===================== -->
    <Style x:Key="StatCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DashCardBg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20,16"/>
        <Setter Property="MinWidth" Value="160"/>
    </Style>

    <!-- ===================== SECTION HEADER ===================== -->
    <Style x:Key="DashSectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource DashTextPrimary}"/>
    </Style>

    <Style x:Key="DashViewAllBtn" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource DashViewAll}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Text" Value="View All"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ===================== ACTIVE DOWNLOAD ROW ===================== -->
    <Style x:Key="DashTableRowStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashBorder}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- ===================== STATUS BADGES ===================== -->
    <Style x:Key="StatusBadgeDownloading" TargetType="Border">
        <Setter Property="Background" Value="#E0F2FE"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <Style x:Key="StatusBadgeCompleted" TargetType="Border">
        <Setter Property="Background" Value="#DCFCE7"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <Style x:Key="StatusBadgePaused" TargetType="Border">
        <Setter Property="Background" Value="#FEF3C7"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <Style x:Key="StatusBadgeFailed" TargetType="Border">
        <Setter Property="Background" Value="#FEE2E2"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- ===================== EMPTY STATE ===================== -->
    <Style x:Key="EmptyStateIcon" TargetType="fa:ImageAwesome">
        <Setter Property="Width" Value="60"/>
        <Setter Property="Foreground" Value="#D1D5DB"/>
    </Style>

    <Style x:Key="EmptyStateTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#6B7280"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="EmptyStateSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#9CA3AF"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,6,0,0"/>
    </Style>

    <!-- ===================== DASH PROGRESS BAR ===================== -->
    <Style x:Key="DashProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Background" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                        <Border x:Name="PART_Track" CornerRadius="3"/>
                        <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="3"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
